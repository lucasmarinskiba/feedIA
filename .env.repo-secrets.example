# FeedIA — Repository-level GitHub Secrets
# Copy to .env.repo-secrets and fill values.
# These secrets are shared across all environments.

SUPABASE_ACCESS_TOKEN=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
GITHUB_TOKEN=             # auto-provided by GitHub Actions, not needed locally
ADMIN_WEBHOOK_URL=
ALERT_EMAIL=

# Backup storage (optional)
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
BACKUP_AWS_ACCESS_KEY_ID=
BACKUP_AWS_SECRET_ACCESS_KEY=
BACKUP_AWS_REGION=
