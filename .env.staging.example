# FeedIA — Staging Environment
# Copy to .env.staging and fill values.

NODE_ENV=staging
PUBLIC_BASE_URL=https://staging-feedia.vercel.app

# Supabase (staging project)
SUPABASE_URL=https://<staging>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis / Upstash (TCP)
REDIS_URL=rediss://default:...@...upstash.io:6379

# Auth
SESSION_SECRET=

# AI
ANTHROPIC_API_KEY=

# Vercel
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Worker deploy (one of these)
RENDER_DEPLOY_HOOK_STAGING=
# RAILWAY_TOKEN_STAGING=
# FLY_API_TOKEN_STAGING=

# Smoke tests
OWNER_TEST_EMAIL=lucasdmarin@gmail.com
OWNER_TEST_PASSWORD=
