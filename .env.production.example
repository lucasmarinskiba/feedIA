# FeedIA — Production Environment
# Copy to .env.production and fill values.

NODE_ENV=production
PUBLIC_BASE_URL=https://feedia.vercel.app

# Supabase (production project)
SUPABASE_URL=https://<production>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis / Upstash (TCP)
REDIS_URL=rediss://default:...@...upstash.io:6379

# Auth
SESSION_SECRET=

# AI
ANTHROPIC_API_KEY=

# Vercel
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Worker deploy (one of these)
RENDER_DEPLOY_HOOK_PROD=
# RAILWAY_TOKEN_PROD=
# FLY_API_TOKEN_PROD=

# Smoke tests
OWNER_TEST_EMAIL=lucasdmarin@gmail.com
OWNER_TEST_PASSWORD=

# Monitoring (optional)
SENTRY_DSN=
LOGTAIL_SOURCE_TOKEN=
ADMIN_WEBHOOK_URL=
ALERT_EMAIL=
