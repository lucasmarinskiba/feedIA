# Claude (cerebro del agente)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_PRIMARY=claude-opus-4-7
CLAUDE_MODEL_FAST=claude-sonnet-4-6

# Meta Graph API (publicación + DMs + comentarios)
META_ACCESS_TOKEN=
META_IG_BUSINESS_ID=
META_PAGE_ID=

# Meta OAuth (login flow para usuarios IG/FB) — habilita /api/auth/instagram/login
META_APP_ID=
# META_APP_SECRET ya configurado más abajo para webhook firma

# TikTok Display API + OAuth — habilita /api/auth/tiktok/login + datos reales
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=          # opcional: token estático single-tenant
TIKTOK_OPEN_ID=               # opcional

# Browserless automation (cloud browser para Instagram engagement)
# Signup: https://www.browserless.io/
# Usado para like/comment/follow/story-view actions
BROWSERLESS_API_KEY=          # Bearer token de Browserless.io

# Stripe billing — checkout + webhooks
STRIPE_SECRET_KEY=                  # sk_live_... o sk_test_...
STRIPE_WEBHOOK_SECRET=              # whsec_... (verificación firma webhook)
PUBLIC_BASE_URL=https://feedia.vercel.app

# Price IDs — Mensual
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_GOLD=
STRIPE_PRICE_PREMIUM=

# Price IDs — Anual (descuento −30%)
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_GOLD_ANNUAL=
STRIPE_PRICE_PREMIUM_ANNUAL=

# Price IDs — Credit Packs (overage video credits, one-time purchase)
STRIPE_PRICE_CREDITPACK_SMALL=        # 200 credits = $5
STRIPE_PRICE_CREDITPACK_MEDIUM=       # 600 credits = $12 (-20%)
STRIPE_PRICE_CREDITPACK_LARGE=        # 1500 credits = $25 (-33%)
STRIPE_PRICE_CREDITPACK_MEGA=         # 5000 credits = $70 (-44%)

# Vercel KV / Upstash (sesiones + users + tokens OAuth + subscription state)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Redis TCP (REQUERIDO para producción: BullMQ workers + caché + observabilidad)
# Upstash proporciona una URL tipo rediss://default:...@...upstash.io:6379
REDIS_URL=                        # redis:// o rediss:// para BullMQ
REDIS_TLS_REJECT_UNAUTHORIZED=    # en Upstash dejar vacío o '0' para self-signed certs

# ── Workers / Colas ──────────────────────────────────────────────────────────
WORKERS_ENABLED=true              # false para deshabilitar workers en local
WORKER_CONCURRENCY=3              # jobs concurrentes por worker
MAX_JOB_ATTEMPTS=3                # reintentos antes de mandar a dead letter

# Automatización (uno de estos para ejecutar acciones reales)
MAKE_WEBHOOK_URL=
N8N_WEBHOOK_URL=
ZAPIER_WEBHOOK_URL=

# CRM (sync de leads desde DMs)
CRM_PROVIDER=notion           # notion | hubspot | salesforce | none
CRM_API_KEY=
CRM_DATABASE_ID=

# Canva Connect API
# Opción A: token estático (legacy, single-tenant)
CANVA_API_TOKEN=

# Opción B: OAuth multi-usuario (recomendado para agencias)
# 1. Crear UNA integración en https://www.canva.com/developers/
# 2. Agregar redirect URI: http://localhost:7321/oauth/callback/canva
# 3. Configurar Client ID y Secret acá
# 4. Cada cliente conecta su propia cuenta vía:
#    CLI:  npm run dev canva-connect --handle=@usuario
#    Web:  http://localhost:7321/connect/canva?handle=@usuario
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# CANVA_REFRESH_TOKEN: fallback global si no se especifica userHandle.
# En modo multi-usuario no es necesario — cada usuario guarda su propio refresh token.
CANVA_REFRESH_TOKEN=

# Brand templates en Canva (IDs de tus templates con campos parametrizados)
CANVA_TEMPLATE_CARRUSEL=
CANVA_TEMPLATE_REEL=
CANVA_TEMPLATE_HISTORIA=
CANVA_TEMPLATE_POST_IMAGEN=

# Otros generadores visuales (futuros)
ZEBRACAT_API_KEY=
INVIDEO_API_KEY=

# Adobe Express / Firefly (futuro)
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=

# Figma (futuro)
FIGMA_API_TOKEN=

# CapCut / InShot (vía webhook a Make/n8n — no tienen API pública)
CAPCUT_WEBHOOK_URL=               # webhook específico para flujos de CapCut
CAPCUT_WEBHOOK_SECRET=            # secreto para firmar/verificar payloads de CapCut
INSHOT_WEBHOOK_URL=               # webhook específico para flujos de InShot
INSHOT_WEBHOOK_SECRET=            # secreto para firmar/verificar payloads de InShot

# Generación de imágenes (Replicate / OpenAI / Flux)
IMAGE_GEN_PROVIDER=none           # replicate | openai | flux | sdxl | none
REPLICATE_API_TOKEN=
REPLICATE_MODEL=black-forest-labs/flux-schnell
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3

# Bot conversacional (DMs + comentarios)
BOT_AUTO_REPLY_ENABLED=false
BOT_POLL_INTERVAL_SECONDS=60
BOT_MAX_AUTO_REPLIES_PER_USER_PER_DAY=3
BOT_QUIET_HOURS_START=23
BOT_QUIET_HOURS_END=8
BOT_ESCALATE_THRESHOLD=0.7

# Notificaciones (Slack y/o webhook genérico)
SLACK_WEBHOOK_URL=
NOTIFICATIONS_WEBHOOK_URL=

# Daemon (HTTP server + scheduler + webhook)
DAEMON_PORT=7321
SERVER_BASE_URL=                   # URL pública del servidor, usada por webhooks de retorno (ej: https://feedia.vercel.app)
CAPCUT_WEBHOOK_RETURN_URL=         # URL forzada de retorno para CapCut (default: {SERVER_BASE_URL}/api/webhook/capcut)
SESSION_SECRET=                    # string largo aleatorio para firmar cookies (REQUERIDO en producción)
META_VERIFY_TOKEN=                 # token cualquiera, lo usás al registrar el webhook en Meta
META_APP_SECRET=                   # app secret de tu app de Meta para validar firma X-Hub-Signature-256

# Compliance y seguridad (OBLIGATORIO leer TERMS_OF_SERVICE.md antes de desactivar)
COMPLIANCE_STRICT_MODE=true           # true: bloquea también violaciones de severidad media
COMPLIANCE_ACCEPTED_TERMS=false       # DEBE cambiar a true después de leer TERMS_OF_SERVICE.md
COMPLIANCE_MAX_DAILY_PUBLISH=15       # máximo posts por día (incluye stories)
COMPLIANCE_MAX_DAILY_DM=100           # máximo DMs por día
COMPLIANCE_MAX_DAILY_COMMENTS=200     # máximo comentarios por día
COMPLIANCE_AUDIT_RETENTION_DAYS=90    # días de retención de logs de auditoría

# ── Proveedores de IA open-source ─────────────────────────────────────────────

# Groq (LLM ultrarrápido gratuito — recomendado)
GROQ_API_KEY=                          # https://console.groq.com → API Keys

# HuggingFace Inference API (modelos gratuitos de ML/NLP/imagen)
HUGGINGFACE_TOKEN=                     # https://huggingface.co/settings/tokens

# OpenRouter (acceso a 200+ modelos, incluye opciones gratuitas)
OPENROUTER_API_KEY=                    # https://openrouter.ai/keys

# Ollama (LLM local, sin costo ni internet)
OLLAMA_HOST=http://localhost:11434     # URL del servidor Ollama local
OLLAMA_DEFAULT_MODEL=llama3.2          # modelo por defecto

# ── Audio mixer cloud (mezcla real voiceover + música + SFX) ──────────────────
AUDIO_MIXER_URL=
AUDIO_MIXER_API_KEY=

# ── Voz (TTS / STT) ───────────────────────────────────────────────────────────

# ElevenLabs (voz más humana — opcional, tiene tier gratuito)
ELEVENLABS_API_KEY=                    # https://elevenlabs.io → Profile → API Key
ELEVENLABS_VOICE_ID=                   # ID de la voz de Talía (dejar vacío para usar default)

# Proveedor TTS preferido (orden de fallback: elevenlabs → google → sapi)
TTS_PROVIDER=sapi                      # elevenlabs | google | sapi
TTS_LANGUAGE=es-AR                     # idioma por defecto para TTS

# Idioma para STT (reconocimiento de voz del navegador / Windows SAPI)
STT_LANGUAGE=es-AR                     # es-AR | en-US | pt-BR | fr-FR | etc.

# ── Internacionalización ──────────────────────────────────────────────────────

# Idioma del sistema FeedIA
FEEDIA_LANGUAGE=es-AR                  # es-AR | en-US | pt-BR | fr-FR | it-IT | de-DE

# ── Base de datos open-source (Supabase) ──────────────────────────────────────
# REQUERIDO para producción con multi-tenancy + RLS.

SUPABASE_URL=                          # https://<proyecto>.supabase.co
SUPABASE_ANON_KEY=                     # clave anon/pública del proyecto Supabase
SUPABASE_SERVICE_ROLE_KEY=             # clave de servicio (server-side only, nunca en frontend)

# Cifrado de tokens OAuth (REQUERIDO en producción; mínimo 16 caracteres)
OAUTH_TOKEN_SECRET=

# ── Multi-cuenta ──────────────────────────────────────────────────────────────

ACTIVE_BRAND_ID=default                # ID de la marca activa. Cada marca tiene su JSON en data/brands/{id}.json

# ── Email (Resend / SendGrid / SMTP) ──────────────────────────────────────────

EMAIL_PROVIDER=none                    # resend | sendgrid | smtp | none
EMAIL_FROM_ADDRESS=agent@paithonlabs.com
EMAIL_FROM_NAME=Paithon Labs Agent
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Video (Reels) ─────────────────────────────────────────────────────────────

VIDEO_PROVIDER=none                    # replicate | ffmpeg | api | none
VIDEO_API_URL=                         # URL de API externa para generación de video
VIDEO_API_KEY=
REPLICATE_VIDEO_MODEL=stability-ai/stable-video-diffusion

# ── DM Webhook (Messenger API para DMs, ya que IG Graph API no permite DMs) ───

META_DM_WEBHOOK_URL=                   # Webhook a un servicio con Messenger API para enviar/recibir DMs

# ── Tendencias (Reddit, Google Trends via SerpAPI, Twitter/X) ─────────────────

REDDIT_SUBREDDITS=instagram,socialmedia,marketing
SERPAPI_KEY=                           # https://serpapi.com/manage-api-key
TWITTER_BEARER_TOKEN=                  # https://developer.twitter.com/en/portal/dashboard

# ── Competidores (RapidAPI, Apify, o webhook propio) ──────────────────────────

RAPIDAPI_KEY=                          # https://rapidapi.com/developer/dashboard
APIFY_API_TOKEN=                       # https://console.apify.com/account/integrations
COMPETITOR_WEBHOOK_URL=                # Webhook propio que devuelve datos de competidores

# ── Modo de operación
DRY_RUN=true                  # true: nada se publica, todo sale por consola/disco
LOG_LEVEL=info
TIMEZONE=America/Argentina/Buenos_Aires

# ── Seguridad del frontend ───────────────────────────────────────────────────
FRONTEND_CSP=                 # Content-Security-Policy para inyectar en index.html
MINIFY=true                   # false para builds de desarrollo sin minificación

# ── Monitoreo (solo owner + colaboradores) ───────────────────────────────────
SENTRY_DSN=                   # DSN de Sentry para errores frontend/backend
SENTRY_AUTH_TOKEN=            # Token para source maps en release (nunca en el bundle)
LOGTAIL_SOURCE_TOKEN=         # Token de Logtail/Better Stack para logs centralizados

# ── Control de versiones / feature flags ─────────────────────────────────────
FEATURE_FLAGS_TABLE=         # tabla de Supabase con flags (ej: feature_flags)
RELEASE_GATE_OWNER_ONLY=true  # solo owner/equipo puede ver canary releases
