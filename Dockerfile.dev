# Development image for FeedIA.
# Includes build tools for native modules (better-sqlite3) and mounts the source code.

FROM node:20-bookworm

RUN apt-get update && apt-get install -y \
    python3 \
    make \
    g++ \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Prevent git errors when running as root in the container
ENV GIT_CONFIG_GLOBAL=/tmp/.gitconfig
RUN git config --global --add safe.directory /app || true

CMD ["tail", "-f", "/dev/null"]
