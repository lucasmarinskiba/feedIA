{
  "version": 2,
  "buildCommand": "npm run build && mkdir -p public && cp -r dist-static/* public/",
  "env": {
    "NODE_ENV": "production",
    "DEPLOY_TIME": "2026-07-13-17-50"
  },
  "routes": [
    {
      "src": "/api(.*)",
      "dest": "/api"
    },
    {
      "src": "/.*",
      "dest": "/api"
    }
  ]
}
