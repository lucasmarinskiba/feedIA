// ─── RECIPE 5: Repurpose Blog to All ───
export const repurposeBlogToAll = async (
  brand: BrandProfile,
  input: RecipeInput,
): Promise<RecipeOutput> => {
  const titulo = input.idea;
  const texto = (input.extraParams?.['texto'] as string) ?? '';
  const { repurposeContent } = await import('../repurposing/index.js');
  const repurposed = await repurposeContent(brand, { tipo: 'blog', titulo, texto });

  const contentPieces: RecipeOutput['contentPieces'] = [];
  const renderResults: ContentAsset[] = [];

  // Render each piece
  const runner = getDefaultRunner();
  for (const piece of repurposed.pieces) {
    const format = piece.format === 'carrusel' ? 'png' : piece.format === 'reel' ? 'mp4' : 'png';
    const templateFormat = piece.format === 'carrusel' ? 'carrusel' : piece.format === 'reel' ? 'reel' : 'post-imagen';
    const render = await runner.render({
      id: `recipe-repurpose-${piece.format}-${Date.now()}`,
      recipeId: 'repurpose-blog-to-all',
      format,
      title: `${piece.format} — ${titulo.slice(0, 30)}`,
      brandProfileId: brand.name,
      assets: [],
      fields: { content: piece.content, format: piece.format },
      options: { templateFormat },
    });
    contentPieces.push({
      format: piece.format,
      title: piece.title,
      caption: piece.caption,
      hashtags: piece.hashtags,
      assets: renderToAssets([render]),
      renderResults: [render],
    });
    renderResults.push(...renderToAssets([render]));
  }

  return {
    recipeId: 'repurpose-blog-to-all',
    ok: contentPieces.every((p) => p.renderResults.every((r) => r.ok)),
    contentPieces,
    pipelineResults: [],
  };
};

// ─── RECIPE 6: Weekly Content Package ───
export const weeklyContentPackage = async (
  brand: BrandProfile,
  input: RecipeInput,
): Promise<RecipeOutput> => {
  const theme = input.idea;
  const runner = getDefaultRunner();
  const contentPieces: RecipeOutput['contentPieces'] = [];

  // 3 Reels
  for (let i = 0; i < 3; i++) {
    const reelIdea = `${theme} — parte ${i + 1}`;
    const reel = await createReel(brand, reelIdea, 30);
    const render = await runner.render({
      id: `recipe-weekly-reel-${i}-${Date.now()}`,
      recipeId: 'weekly-content-package',
      format: 'mp4',
      title: `Reel ${i + 1} — ${theme.slice(0, 30)}`,
      brandProfileId: brand.name,
      assets: [],
      fields: {
        hook_visual: reel.hookVisual,
        cta: reel.cta,
        audio_sugerido: reel.audioSugerido,
      },
      options: { templateFormat: 'reel' },
    });
    contentPieces.push({
      format: 'reel',
      title: reelIdea,
      assets: renderToAssets([render]),
      renderResults: [render],
    });
  }

  // 2 Carruseles
  for (let i = 0; i < 2; i++) {
    const carruselIdea = `${theme} — guía ${i + 1}`;
    const carrusel = await createCarrusel(brand, carruselIdea, 'medio');
    const render = await runner.render({
      id: `recipe-weekly-carrusel-${i}-${Date.now()}`,
      recipeId: 'weekly-content-package',
      format: 'png',
      title: `Carrusel ${i + 1} — ${theme.slice(0, 30)}`,
      brandProfileId: brand.name,
      assets: [],
      fields: {
        ...carrusel.slides.reduce((acc, s, idx) => {
          acc[`titulo_${idx + 1}`] = s.titulo;
          acc[`cuerpo_${idx + 1}`] = s.cuerpo;
          return acc;
        }, {} as Record<string, string>),
      },
      options: { templateFormat: 'carrusel' },
    });
    contentPieces.push({
      format: 'carrusel',
      title: carruselIdea,
      assets: renderToAssets([render]),
      renderResults: [render],
    });
  }

  // 14 Stories (2 por día)
  const stories = await createStorySequence(brand, theme, 14);
  const render = await runner.render({
    id: `recipe-weekly-stories-${Date.now()}`,
    recipeId: 'weekly-content-package',
    format: 'png',
    title: `Stories semana — ${theme.slice(0, 30)}`,
    brandProfileId: brand.name,
    assets: [],
    fields: {
      ...stories.slides.reduce((acc, s, idx) => {
        acc[`story_${idx + 1}`] = s.textoPrincipal;
        return acc;
      }, {} as Record<string, string>),
    },
    options: { templateFormat: 'historia', storyCount: 14 },
  });
  contentPieces.push({
    format: 'historia',
    title: `${theme} — stories semanales`,
    assets: renderToAssets([render]),
    renderResults: [render],
  });

  return {
    recipeId: 'weekly-content-package',
    ok: contentPieces.every((p) => p.renderResults.every((r) => r.ok)),
    contentPieces,
    pipelineResults: [],
  };
};

