// @ts-nocheck
import type { BrandProfile } from '../../config/types.js';
import type { RecipeInput, RecipeOutput, ContentAsset } from '../../studio/types.js';
import { getDefaultRunner } from '../../studio/index.js';
import { createReel, createCarrusel, createStorySequence, createCaption } from '../content/index.js';
import { generateHooks } from '../copywriting/index.js';
import { investigarHashtags, buildPostHashtags } from '../hashtags/index.js';
import { auditReceptorResponsibility } from '../ethics/index.js';
import { scoreAesthetic } from '../aesthetic/index.js';
import { log } from '../../agent/logger.js';

// Helper to convert studio render results to recipe output
const renderToAssets = (renderResults: Array<{ artifactUrls?: string[]; format: string }>): ContentAsset[] => {
  const assets: ContentAsset[] = [];
  for (const rr of renderResults) {
    if (rr.artifactUrls) {
      rr.artifactUrls.forEach((url, idx) => {
        assets.push({
          id: `asset-${idx}-${Date.now()}`,
          type: rr.format === 'mp4' ? 'video' : 'image',
          source: 'generated',
          url,
        });
      });
    }
  }
  return assets;
};

// ─── RECIPE 1: Reel Faceless Tutorial ───
export const reelFacelessTutorial = async (
  brand: BrandProfile,
  input: RecipeInput,
): Promise<RecipeOutput> => {
  const idea = input.idea;
  const reel = await createReel(brand, idea, 30);
  const hooks = await generateHooks(brand, idea);
  const topHook = hooks.ranked[0]?.text ?? reel.hookText;
  const caption = await createCaption(brand, idea, 'reel');
  const hashtags = await investigarHashtags(brand, idea);
  const selected = buildPostHashtags(
    { mega: [], grande: [], medio: [], nicho: [], marca: [] },
    { mega: 0, grande: 0, medio: 0, nicho: 0, marca: 0 },
  );

  const runner = getDefaultRunner();
  const render = await runner.render({
    id: `recipe-reel-faceless-${Date.now()}`,
    recipeId: 'reel-faceless-tutorial',
    format: 'mp4',
    title: `Reel Faceless — ${idea.slice(0, 40)}`,
    brandProfileId: brand.name,
    assets: [],
    fields: {
      hook_visual: reel.hookVisual,
      hook_text: topHook,
      cta: reel.cta,
      audio_sugerido: reel.audioSugerido,
      ...reel.beats.reduce((acc, b, i) => {
        acc[`texto_pantalla_${i + 1}`] = b.textoEnPantalla;
        acc[`broll_${i + 1}`] = b.bRoll;
        return acc;
      }, {} as Record<string, string>),
    },
    options: { templateFormat: 'reel', count: 1 },
  });

  const ethics = auditReceptorResponsibility(brand, caption.variants.media, [topHook]);

  return {
    recipeId: 'reel-faceless-tutorial',
    ok: render.ok && ethics.passes,
    contentPieces: [
      {
        format: 'reel',
        title: idea,
        caption: caption.variants.media,
        hashtags: selected,
        assets: renderToAssets([render]),
        renderResults: [render],
      },
    ],
    pipelineResults: [],
    error: render.error || (ethics.passes ? undefined : `Ética: ${ethics.issues.join('; ')}`),
  };
};

// ─── RECIPE 2: Carrusel Educativo ───
export const carruselEducativo = async (
  brand: BrandProfile,
  input: RecipeInput,
): Promise<RecipeOutput> => {
  const idea = input.idea;
  const longitud = (input.extraParams?.['longitud'] as 'corto' | 'medio' | 'largo') ?? 'medio';
  const carrusel = await createCarrusel(brand, idea, longitud);
  const caption = await createCaption(brand, idea, 'carrusel');

  const runner = getDefaultRunner();
  const render = await runner.render({
    id: `recipe-carrusel-edu-${Date.now()}`,
    recipeId: 'carrusel-educativo',
    format: 'png',
    title: `Carrusel — ${idea.slice(0, 40)}`,
    brandProfileId: brand.name,
    assets: [],
    fields: {
      ...carrusel.slides.reduce((acc, s, i) => {
        acc[`titulo_${i + 1}`] = s.titulo;
        acc[`cuerpo_${i + 1}`] = s.cuerpo;
        return acc;
      }, {} as Record<string, string>),
      hashtags: carrusel.hashtags.join(' '),
    },
    options: { templateFormat: 'carrusel' },
  });

  const ethics = auditReceptorResponsibility(brand, caption.variants.media, carrusel.slides.map((s) => s.titulo));

  return {
    recipeId: 'carrusel-educativo',
    ok: render.ok && ethics.passes,
    contentPieces: [
      {
        format: 'carrusel',
        title: idea,
        caption: caption.variants.media,
        hashtags: carrusel.hashtags,
        assets: renderToAssets([render]),
        renderResults: [render],
      },
    ],
    pipelineResults: [],
    error: render.error || (ethics.passes ? undefined : `Ética: ${ethics.issues.join('; ')}`),
  };
};

// ─── RECIPE 3: Story Sequence Launch ───
export const storySequenceLaunch = async (
  brand: BrandProfile,
  input: RecipeInput,
): Promise<RecipeOutput> => {
  const evento = input.idea;
  const cantidad = Number(input.extraParams?.['cantidad'] ?? 5);
  const stories = await createStorySequence(brand, evento, cantidad);

  const runner = getDefaultRunner();
  const render = await runner.render({
    id: `recipe-story-launch-${Date.now()}`,
    recipeId: 'story-sequence-launch',
    format: 'png',
    title: `Stories — ${evento.slice(0, 40)}`,
    brandProfileId: brand.name,
    assets: [],
    fields: {
      ...stories.slides.reduce((acc, s, i) => {
        acc[`story_${i + 1}`] = s.textoPrincipal;
        return acc;
      }, {} as Record<string, string>),
    },
    options: { templateFormat: 'historia', storyCount: cantidad },
  });

  return {
    recipeId: 'story-sequence-launch',
    ok: render.ok,
    contentPieces: [
      {
        format: 'historia',
        title: evento,
        assets: renderToAssets([render]),
        renderResults: [render],
      },
    ],
    pipelineResults: [],
    error: render.error,
  };
};

