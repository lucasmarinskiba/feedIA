// ─── RECIPE 10: FAQ Faceless Triple ───
export const faqFacelessTriple = async (
  brand: BrandProfile,
  input: RecipeInput,
): Promise<RecipeOutput> => {
  const faqs = input.idea.split('|').map((s) => s.trim()).filter(Boolean);
  const contentPieces: RecipeOutput['contentPieces'] = [];
  const runner = getDefaultRunner();

  for (const faq of faqs.slice(0, 3)) {
    const reel = await createReel(brand, `FAQ: ${faq}`, 20);
    const render = await runner.render({
      id: `recipe-faq-${Date.now()}-${faq.slice(0, 10)}`,
      recipeId: 'faq-faceless-triple',
      format: 'mp4',
      title: `FAQ — ${faq.slice(0, 40)}`,
      brandProfileId: brand.name,
      assets: [],
      fields: {
        hook_visual: reel.hookVisual,
        cta: '¿Tenés más preguntas? Mandá DM',
        audio_sugerido: 'trending FAQ background',
      },
      options: { templateFormat: 'reel' },
    });
    contentPieces.push({
      format: 'reel',
      title: faq,
      assets: renderToAssets([render]),
      renderResults: [render],
    });
  }

  // Carrusel resumen
  const resumenIdea = `Resumen: ${faqs.join(' + ')}`;
  const carrusel = await createCarrusel(brand, resumenIdea, 'corto');
  const renderCarrusel = await runner.render({
    id: `recipe-faq-resumen-${Date.now()}`,
    recipeId: 'faq-faceless-triple',
    format: 'png',
    title: `FAQ Resumen`,
    brandProfileId: brand.name,
    assets: [],
    fields: {
      ...carrusel.slides.reduce((acc, s, i) => {
        acc[`titulo_${i + 1}`] = s.titulo;
        acc[`cuerpo_${i + 1}`] = s.cuerpo;
        return acc;
      }, {} as Record<string, string>),
    },
    options: { templateFormat: 'carrusel' },
  });
  contentPieces.push({
    format: 'carrusel',
    title: resumenIdea,
    assets: renderToAssets([renderCarrusel]),
    renderResults: [renderCarrusel],
  });

  return {
    recipeId: 'faq-faceless-triple',
    ok: contentPieces.every((p) => p.renderResults.every((r) => r.ok)),
    contentPieces,
    pipelineResults: [],
  };
};
