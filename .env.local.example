# FeedIA — Local Development Environment
# Copy to .env.local and adjust values.

NODE_ENV=development
DRY_RUN=true
LOG_LEVEL=debug

# Local Postgres (from docker-compose.yml)
DATABASE_URL=postgres://postgres:postgres@postgres:5432/feedia

# Local Redis (from docker-compose.yml)
REDIS_URL=redis://redis:6379

# Auth
SESSION_SECRET=dev-secret-change-in-production

# AI (optional — required only for LLM features)
ANTHROPIC_API_KEY=

# Email (Mailpit from docker-compose.yml)
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=dev@feedia.local
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# Compliance
COMPLIANCE_ACCEPTED_TERMS=true
COMPLIANCE_MAX_DAILY_PUBLISH=15
COMPLIANCE_MAX_DAILY_DM=100
COMPLIANCE_MAX_DAILY_COMMENTS=200

# Local daemon port
DAEMON_PORT=7321
